# ── db-docker (192.168.0.101) ─────────────────────────────────────────────────
NEO4J_URI=bolt://192.168.0.101:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

QDRANT_HOST=192.168.0.101
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=infragraph

# ── OpenRouter ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Model tiers ───────────────────────────────────────────────────────────────
# Embeddings run locally via sentence-transformers (no API cost)
EMBED_MODEL=intfloat/multilingual-e5-large
EMBED_DIM=1024

# Extraction: structured JSON from text chunks
EXTRACT_MODEL=mistralai/mistral-large-2512

# Chat / answer synthesis
CHAT_MODEL=deepseek/deepseek-v3-0324

# ── OCR (via OpenRouter file-parser — no local installs needed) ───────────────
# pdf-text   = free, embedded text PDFs
# mistral-ocr = scanned / image-heavy PDFs (auto-selected when text is sparse)
# Images (.png .jpg etc) always go through multimodal vision on extract_model

# ── Ingestion ─────────────────────────────────────────────────────────────────
# Comma-separated paths to scan
INGEST_PATHS=/path/to/docs,/path/to/repos
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Normalization ─────────────────────────────────────────────────────────────
# Minimum cosine similarity to consider two entities the same
DEDUP_THRESHOLD=0.92
